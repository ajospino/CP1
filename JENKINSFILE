pipeline {
    agent none

     stages {
        stage('Get Code') {
            agent {label 'nux'}
            steps {
                // Obtener código del repo
                git 'https://github.com/anieto-unir/helloworld.git'
            }
        }

    stage('Build') {
        agent {label 'win'}
        steps {
            echo 'Eyyyy, esto es Python. No hay que compilar nada!!!'
	    echo WORKSPACE
	    bat 'dir'
        }
    }

    stage('Tests')
    {
        parallel {
            stage('Unit') {
                agent {label 'win'}
                steps {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                        bat '''
                                set PYTHONPATH=%WORKSPACE%
                                pytest --junitxml=result-unit.xml test\\unit
                        '''
                    }
                }
            }
            
            stage('Rest') {
                agent {label 'win'}
                steps {
                    bat '''
                        set FLASK_APP=app\\api.py
                        set FLASK_ENV=development
                        start flask run
                        start java -jar C:\\User\\Admin\\Documents\\wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
                        set PYTHONPATH=%WORKSPACE%
                        pytest --junitxml=result-rest.xml test\\rest
                    '''
                }    
            }    
        }
    }
    
    stage ('Results') {
        agent {label 'nux'}
        steps {
            junit 'result*.xml'
        }
    }
  }
}
