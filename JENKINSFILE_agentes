pipeline {
    agent none

     stages {
        stage('Get Code') {
            agent {label 'nux'}
            steps {
                // Obtener código del repo
                git 'https://github.com/ajospino/CP1.git'
            }
        }

        stage('Tests on Windows')
        {
            parallel {
                stage('Unit and Coverage') {
                    agent {label 'win'}
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            bat '''
                                set PYTHONPATH=%WORKSPACE%
                                coverage run -m pytest --junitxml=result-unit.xml test\\unit
                                coverage xml -o result-coverage.xml
                            '''
                        }
                        recordCoverage(tools: [[parser: 'COBERTURA', pattern: 'result-coverage.xml'], [parser: 'JUNIT', pattern: 'result-unit.xml']])
                    }
                }

                stage('Rest') {
                    agent {label 'win'}
                    steps {
                        bat '''
                            set FLASK_APP=app\\api.py
                            set FLASK_ENV=development
                            start flask run
                            start java -jar C:\\Users\\Admin\\Documents\\wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
                            pytest --junitxml=result-rest.xml test\\rest
                        '''
                        recordCoverage(tools: [[parser: 'JUNIT', pattern: 'result-rest.xml']])
                    }    
                }

                stage('Performance') {
                    agent {label 'win'}
                    steps {
                        bat '''
                            set FLASK_APP=app\\api.py
                            set FLASK_ENV=development
                            start flask run
                            jmeter -n -t test/jmeter/flask.jmx -l result-performance.xml
                        '''
                        perfReport 'result-performance.xml'
                    }    
                }   
            } 

        }
        stage ('Tests on Linux'){
            parallel {
                  stage('Static') {
                    agent {label 'nux'}
                    steps {
                        sh 'python -m flake8 --exit-zero --output-file=result-static.xml app/'
                        recordIssues tools: [flake8(pattern: 'result-static.xml')], qualityGates:[[threshold: 8, type: 'TOTAL', unstable: true]], unhealthy: 10 

                    }    
                }

                stage('Security') {
                    agent {label 'nux'}
                    steps {
                        sh 'python -m bandit -r app/ -f xml -o result-security.xml'
                        recordIssues tools: [pyLint(name:'Security', pattern: 'result-security.xml')], qualityGates:[[threshold: 2, type: 'TOTAL', unstable: true]], unhealthy: 4
                    }    
                } 
            }
        }
  }
    post {
        always {
            cleanWs(cleanWhenNotBuilt: false,
                    deleteDirs: true,
                    notFailBuild: true)
        }
    }
}
