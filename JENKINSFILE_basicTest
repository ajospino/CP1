pipeline {
    agent {label 'win'}
      stages {
        stage('Test and Run') {
            steps{
                git 'https://github.com/ajospino/CP1.git'
                
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    bat '''
                            set PYTHONPATH=%WORKSPACE%
                            coverage run -m pytest --junitxml=result-unit.xml test\\unit
                            coverage xml -o result-coverage.xml
                    '''
                }
                recordCoverage(tools: [[parser: 'COBERTURA', pattern: 'result-coverage.xml'], [parser: 'JUNIT', pattern: 'result-unit.xml']])
                
                bat '''
                    set FLASK_APP=app\\api.py
                    set FLASK_ENV=development
                    start flask run
                    start java -jar C:\\Users\\Admin\\Documents\\wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
                    set PYTHONPATH=%WORKSPACE%
                    pytest --junitxml=result-rest.xml test\\rest
                '''
                
                catchError(buildResult:'SUCCESS' , stageResult: 'UNSTABLE') {
                    bat 'flake8 --exit-zero --output-file=result-static.xml app/'
                }
                recordIssues tools: [flake8(pattern: 'result-static.xml')], qualityGates:[[threshold: 8, type: 'TOTAL', unstable: true], [criticality: 'FAILURE', threshold: 10, type: 'TOTAL', unstable: true]], unhealthy: 8 
                
                bat '''
                    bandit -r app/ -f xml -o result-security.xml
                '''
                recordIssues tools: [pyLint(name:'Security', pattern: 'result-security.xml')], qualityGates:[[threshold: 2, type: 'TOTAL', unstable: true], [criticality: 'FAILURE', threshold: 4, type: 'TOTAL', unstable: true]], unhealthy: 4
                
                bat '''
                    jmeter -n -t test/jmeter/flask.jmx -l result-performance.xml
                '''
                perfReport 'result-performance.xml'        
            }
        }
      }
    
    post {
        always {
            cleanWs(cleanWhenNotBuilt: false,
                    deleteDirs: true,
                    notFailBuild: true)
        }
    }
}